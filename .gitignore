# Dependencies
node_modules/

# Build outputs
dist/
/release/
release-*/
out/

# IDE
.idea/
*.swp
*.swo
.vscode/*
!.vscode/settings.json
.scratchpad/
.full-review/

# System files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# electron-vite temp files
electron.vite.config.*.mjs

# Claude binary (downloaded at build time)
resources/bin/

# Legacy lockfile (migrated to text-based bun.lock)
bun.lockb

# Claude Code local settings (user-specific, not tracked)
.claude/settings.local.json

# Session ephemeral files
.remember/tmp/save-session.pid

# 1code-api runtime teams config (real Entra group IDs — example template is committed)
services/1code-api/config/teams.yaml

# Git worktrees (isolated workspaces for feature branches)
.worktrees/

# Unencrypted SOPS files (prevent accidental plaintext credential commit)
*.dec.yaml
*.unencrypted.yaml
*.cleartext.yaml
