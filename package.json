{
  "name": "1code-desktop",
  "version": "0.0.85",
  "private": true,
  "description": "1Code - UI for parallel work with AI agents",
  "homepage": "https://apollosai.dev",
  "author": {
    "name": "apollosai.dev",
    "email": "support@apollosai.dev"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --dir",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "dist": "electron-builder",
    "claude:download": "node scripts/download-claude-binary.mjs --version=2.1.96",
    "claude:download:all": "node scripts/download-claude-binary.mjs --version=2.1.96 --all",
    "codex:download": "node scripts/download-codex-binary.mjs --version=0.118.0",
    "codex:download:all": "node scripts/download-codex-binary.mjs --version=0.118.0 --all",
    "release": "rm -rf release && bun i && bun run claude:download && bun run codex:download && bun run build && bun run package:mac",
    "release:dev": "rm -rf release && bun run claude:download && bun run codex:download && bun run build && bun run package:mac && rm -rf node_modules && bun i",
    "icon:generate": "node scripts/generate-icon.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "ts:check": "tsgo --noEmit",
    "lint": "eslint src/ electron-shim.js",
    "test": "bun test",
    "postinstall": "node scripts/rebuild-native-modules.mjs && node scripts/patch-electron-dev.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.161",
    "@anthropic-ai/claude-agent-sdk": "0.2.105",
    "@anthropic-ai/sdk": "^0.88.0",
    "@azure/msal-node": "^5.1.2",
    "@azure/msal-node-extensions": "^5.1.2",
    "@mcpc-tech/acp-ai-provider": "0.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "1.1.15",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/electron": "^7.11.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@zed-industries/codex-acp": "0.11.1",
    "ai": "6.0.159",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "front-matter": "^4.0.2",
    "jose": "^6.2.2",
    "jotai": "^2.19.1",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "1.8.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "pidtree": "^0.6.0",
    "posthog-js": "1.368.0",
    "posthog-node": "5.29.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-icons": "^5.6.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "4.0.2",
    "simple-git": "^3.36.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "trpc-electron": "^0.1.2",
    "unique-names-generator": "^4.7.1",
    "which": "^6.0.1",
    "xterm": "^5.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.24",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.12",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "~41.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "dev.apollosai.agents",
    "productName": "1Code",
    "npmRebuild": true,
    "protocols": [
      {
        "name": "1Code",
        "schemes": [
          "apollosai-agents"
        ]
      },
      {
        "name": "1Code (Dev)",
        "schemes": [
          "apollosai-agents-dev"
        ]
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "drizzle",
        "to": "migrations"
      },
      {
        "from": "resources/bin/${platform}-${arch}",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/bin/VERSION",
        "to": "bin/VERSION"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*",
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
      "node_modules/@zed-industries/codex-acp/**/*",
      "node_modules/@zed-industries/codex-acp-*/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "1Code needs microphone access for voice dictation"
      }
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 150,
          "type": "file"
        },
        {
          "x": 400,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "iconSize": 80
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "jrmatherly",
      "repo": "1dev"
    }
  },
  "pnpm": {
    "overrides": {
      "source-map-support>source-map": "0.7.4"
    }
  }
}
