{
  // UI Setting:
  // TypeScript (Native Preview) > Use Tsgo
  "js/ts.experimental.useTsgo": true,
  "mirrord.promptUsingBinary": false,

  // ──────────────────────────────────────────────────────────────────────
  // SONARLINT RULE SUPPRESSIONS
  //
  // IMPORTANT: SonarLint's "sonarlint.rules" setting has scope "application",
  // which means VS Code IGNORES it in workspace settings (.vscode/settings.json).
  // It only takes effect in your User settings.
  //
  // To apply these suppressions:
  //   1. Open Command Palette (Cmd+Shift+P)
  //   2. Run "Preferences: Open User Settings (JSON)"
  //   3. Copy the "sonarlint.rules" block below into your User settings
  //
  // This file is tracked in git as documentation of which rules are
  // suppressed and why. Each rule was investigated on 2026-04-10 and
  // deliberately skipped — see inline comments for rationale.
  // ──────────────────────────────────────────────────────────────────────
  "sonarlint.rules": {
    // S6478: "Move component out of parent" — 44 nested components in
    // chat-markdown-renderer.tsx. This is a deliberate architecture choice;
    // refactoring would be a major initiative with no correctness benefit.
    "typescript:S6478": { "level": "off" },

    // S7764: "Prefer globalThis over window" — 17 occurrences. In Electron's
    // renderer process, `window` is the canonical global object. `globalThis`
    // is functionally identical but less idiomatic for browser/Electron code.
    "typescript:S7764": { "level": "off" },

    // S7781: "Prefer replaceAll over replace" — 10 occurrences. All use
    // regex with /g flag (e.g. replace(/&/g, "&amp;")). replaceAll with a
    // /g regex is functionally identical but adds no clarity or safety.
    "typescript:S7781": { "level": "off" },

    // S7735: "Unexpected negated condition" — guard-clause pattern
    // (if (!mounted) return null) is idiomatic React and used throughout
    // the codebase. SonarLint prefers positive conditions but that conflicts
    // with the early-return guard pattern.
    "typescript:S7735": { "level": "off" },

    // S3358: "Extract nested ternary" — 1 occurrence in update-banner.tsx.
    // 3-way mock flag branch is readable as nested ternary. Extracting to
    // if/else would add verbosity without improving comprehension.
    "typescript:S3358": { "level": "off" },

    // S2486: "Handle this exception" — 1 occurrence in electron-shim.js.
    // Empty catch in require() monkey-patch is intentional: if electronBinding
    // fails, execution falls through to originalRequire() as the final fallback.
    "javascript:S2486": { "level": "off" },

    // S3776: "Cognitive Complexity too high" — 3 functions in codex-tool-normalizer.ts
    // (normalizeCodexToolInput=65, normalizeCodexToolPart=26, normalizeCodexStreamChunk=23).
    // These are flat normalizer dispatchers with independent per-tool-type branches.
    // High scores come from many cases, not convoluted logic. Splitting would scatter
    // related normalization without reducing actual complexity.
    "typescript:S3776": { "level": "off" },

    // S4325: "Unnecessary type assertion" — 1 occurrence in codex-tool-normalizer.ts.
    // `rawInput.args as AnyRecord` is required because TS loses type-guard narrowing
    // when the guard result is stored in an intermediate variable (`hasArgsWrapper`).
    // SonarLint doesn't model TS narrowing limitations — this is a false positive.
    "typescript:S4325": { "level": "off" },

    // S6551: "Object stringification" — 1 occurrence in remote-trpc.ts.
    // `input.toString()` only reached for URL/Request objects which have
    // meaningful toString() implementations. False positive.
    "typescript:S6551": { "level": "off" },

    // S7787: "Empty export" — 1 occurrence in wdyr.ts.
    // `export {}` is required to force module scope so `import.meta.env`
    // works in a side-effect-only file. Standard TS idiom.
    "typescript:S7787": { "level": "off" },

    // S6571: "Literal overridden by string in union" — 2 in diff-view-highlighter.ts.
    // `"class" | "style" | string` is a documentation pattern that hints expected
    // values to IDE autocomplete while accepting any string. Intentional.
    "typescript:S6571": { "level": "off" },

    // S6564: "Redundant type alias" — 1 in message-parser.ts.
    // `MessagePart = AnyObj` is a semantic alias used in 10+ places. Removing it
    // would hurt readability by losing the domain-specific name.
    "typescript:S6564": { "level": "off" },

    // S4666: "Duplicate CSS selector" — 1 in agents-styles.css.
    // Two `[data-agents-page]` blocks are in different logical sections (theme
    // overrides vs scrollbar styles) with disjoint properties. Intentional separation.
    "css:S4666": { "level": "off" },

    // S7764/S3358 JavaScript variants — same rules as typescript:S7764 and
    // typescript:S3358 above, but SonarLint reports inline <script> blocks in
    // .html files under the javascript: prefix. Suppressing for the same reasons:
    // window is canonical in Electron renderer, nested ternaries are readable
    // in theme-detection code.
    "javascript:S7764": { "level": "off" },
    "javascript:S3358": { "level": "off" },

    // S7778: "Do not call Array#push() multiple times" — 6 in use-update-checker.ts.
    // Each push() registers a separate event listener with its own closure and
    // log message. Combining them would destroy logical grouping.
    "typescript:S7778": { "level": "off" },

    // S4138: "Use for-of instead of indexed for loop" — 1 in use-voice-recording.ts.
    // Indexed access on Uint8Array is idiomatic for audio/signal processing.
    "typescript:S4138": { "level": "off" },

    // S7763: "Use export...from to re-export" — false positive when the imported
    // type is also used locally (e.g. as a generic parameter). The separate
    // import+export pattern is required to keep the name in scope.
    "typescript:S7763": { "level": "off" },

    // S6759: "Mark props as read-only" — 27 components. Bulk-wrapping every
    // props interface with Readonly<> is a large refactor with no runtime benefit.
    "typescript:S6759": { "level": "off" },

    // S6479: "Do not use Array index in keys" — 8 occurrences in settings tabs.
    // These render static/stable lists (keyboard shortcuts, worktrees) where
    // index keys are safe and items have no stable unique ID.
    "typescript:S6479": { "level": "off" },

    // S6848: "Avoid non-native interactive elements" — Electron desktop app
    // uses custom interactive components; web a11y rules don't apply directly.
    "typescript:S6848": { "level": "off" },

    // S6853: "Form label must be associated with control" — settings dialogs
    // use custom label patterns with Radix UI primitives that handle association.
    "typescript:S6853": { "level": "off" },

    // S2004: "Nesting depth >4" — React component closures in settings tabs
    // naturally nest event handlers inside conditionals inside components.
    "typescript:S2004": { "level": "off" },

    // S2486: "Handle this exception" (typescript variant) — same rationale as
    // javascript:S2486. Intentional empty catches for fallback patterns.
    "typescript:S2486": { "level": "off" },

    // S4323: "Replace union type with type alias" — inline unions in preload
    // types are fine; extracting aliases adds indirection without clarity.
    "typescript:S4323": { "level": "off" },

    // S6767: "Prop defined but never used" — autoStartAuth in ClaudeLoginModal
    // is passed by callers but not yet consumed. Intentional placeholder.
    "typescript:S6767": { "level": "off" },

    // S3735: "Remove void operator" — `void handleAsync()` is an intentional
    // fire-and-forget pattern in React event handlers.
    "typescript:S3735": { "level": "off" },

    // S6772: "Ambiguous spacing after element" — JSX whitespace between
    // inline elements is a style preference, not a bug.
    "typescript:S6772": { "level": "off" },

    // S1082: "Click handler needs keyboard listener" — Electron desktop app;
    // keyboard accessibility is handled at the application shell level.
    "typescript:S1082": { "level": "off" },

    // S1874: "Deprecated API" — React 19 deprecates non-generic event types
    // (FormEvent, ChangeEvent). Fixing requires auditing all form handlers.
    "typescript:S1874": { "level": "off" }
  }
}