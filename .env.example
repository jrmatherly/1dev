# =============================================================================
# Open Source Build Configuration
# =============================================================================
# All variables below are OPTIONAL - the app works without them.
# Set them only if you need code signing, analytics, or error tracking.
# =============================================================================

# Apple Developer credentials (required for macOS code signing & notarization)
# Skip these if you just want to run locally without signing
APPLE_ID=your-email@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_IDENTITY=Developer ID Application: Your Name (TEAM_ID)

# Sentry error tracking (optional - disabled if not set)
# Main process uses MAIN_VITE_ prefix
MAIN_VITE_SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/xxxxx

# PostHog analytics — DISABLED when keys are not set
# Set these to enable analytics (PostHog Cloud or self-hosted)
# Main process (MAIN_VITE_ prefix for electron-vite)
# MAIN_VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAIN_VITE_POSTHOG_HOST=https://us.i.posthog.com
# Renderer process (VITE_ prefix for Vite)
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Community channel URL (optional - hidden when not set)
# Set this to show a community link in the help menu (e.g. Slack workspace invite)
# VITE_COMMUNITY_URL=https://your-workspace.slack.com/...

# Feedback URL (optional - hidden when not set)
# Set this to show a feedback button in the sidebar
# VITE_FEEDBACK_URL=https://your-feedback-channel-or-form/...

# API URL (optional - defaults to https://apollosai.dev)
# Only change this if you're running the web app locally
# MAIN_VITE_API_URL=http://localhost:3000

# Dev Auth Bypass (optional - skips login screen in dev mode)
# Use when the enterprise auth backend (Envoy Gateway + Entra) is not yet deployed.
# NEVER works in packaged/production builds.
# MAIN_VITE_DEV_BYPASS_AUTH=true

# -- Enterprise Entra ID auth (activates MSAL sign-in in the desktop app)
# Required to use "Sign in" on the login screen WITHOUT MAIN_VITE_DEV_BYPASS_AUTH.
# Values come from cluster.yaml in the Talos cluster repo. See:
#   docs/enterprise/entra-app-registration-1code-api.md
#   docs/enterprise/auth-login-button-wire-msal.md
# NOTE: Client/tenant IDs are PUBLIC OAuth2 identifiers, not secrets.
# MAIN_VITE_ENTERPRISE_AUTH_ENABLED is a build-time env override (baked in by Vite);
# both dev and packaged builds use it. CI release.yml reads from GitHub secrets.
# MAIN_VITE_ENTRA_CLIENT_ID=your-client-id
# MAIN_VITE_ENTRA_TENANT_ID=your-tenant-id
# MAIN_VITE_ENTERPRISE_AUTH_ENABLED=true

# -- Dual-mode LLM routing (add-dual-mode-llm-routing)
# Allow direct-to-Anthropic routing for Claude Code Subscription and BYOK accounts.
# When unset or false (default), all routing goes through LiteLLM for audit.
# See openspec/specs/llm-routing/spec.md.
# MAIN_VITE_ALLOW_DIRECT_ANTHROPIC=true
#
# LiteLLM proxy base URL. REQUIRED when MAIN_VITE_ALLOW_DIRECT_ANTHROPIC is false
# or when any profile uses routingMode=litellm. Replaces legacy LITELLM_PROXY_URL.
# MAIN_VITE_LITELLM_BASE_URL=https://llms.<your-cluster-domain>

# Voice Input (optional - uses OpenAI Whisper API)
# Set this to enable voice-to-text for users without a paid subscription
# Get your API key at https://platform.openai.com/api-keys
# MAIN_VITE_OPENAI_API_KEY=sk-...
